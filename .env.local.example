# YouTube Data API v3
YOUTUBE_API_KEY_1=AIzaSy...
YOUTUBE_API_KEY_2=
YOUTUBE_API_KEY_3=

# Cloudflare R2
# S3 endpoint: https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com/<R2_BUCKET_NAME>
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ytdownloader
R2_PUBLIC_DOMAIN=pub-xxxxxxxx.r2.dev

# Subtitle languages for yt-dlp (optional)
# SUBTITLE_LANGS=en,vi,en.*,vi.*

# YouTube download auth (recommended for Cloud Run — export Netscape cookies.txt)
# Local file path:
# YT_DLP_COOKIES_FILE=./cookies.txt
# Or base64 for Cloud Run deploy (base64 -i cookies.txt | tr -d '\n'):
# YT_DLP_COOKIES_B64=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
